              "value": "={{\n`\n<html>\n<head>\n<style>\nbody {\n  font-family: Arial, sans-serif;\n  line-height: 1.6;\n}\n.container {\n  padding: 20px;\n}\n</style>\n</head>\n<body>\n<div class=\"container\">\n\n<h2>Monthly Performance Report</h2>\n\n<p>Hello ${$json.client_name},</p>\n\n<p>Please find your website performance report below.</p>\n\n<hr>\n\n<pre style=\"white-space: pre-wrap; font-family: Arial, sans-serif;\">\n${$json.ai_summary || 'No report content available.'}\n</pre>\n\n<hr>\n\n<p>\nRegards,<br>\nAgencyPulseAI\n</p>\n\n</div>\n</body>\n</html>\n`\n}}",
              "type": "string"
            }
          ]
